---
layout: default
---

<style>
  .book-wrapper {
    display: flex;
    max-width: var(--max-content-width);
    margin: 0 auto;
    padding: 0 15px;
  }
  .book-sidebar {
    width: 250px;
    min-width: 250px;
    position: sticky;
    top: 57px;
    height: calc(100vh - 57px);
    overflow-y: auto;
    padding: 1.5rem 1rem 1.5rem 0;
    border-right: 1px solid var(--global-divider-color);
  }
  .book-sidebar-title {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--global-divider-color);
  }
  .book-sidebar-title a {
    color: var(--global-text-color);
    text-decoration: none;
  }
  .book-sidebar-nav {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .book-sidebar-nav li {
    margin: 0;
  }
  .book-sidebar-nav a {
    display: block;
    padding: 0.4rem 0.75rem;
    color: var(--global-text-color);
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 300;
  }
  .book-sidebar-nav a:hover {
    background: var(--global-theme-color);
    color: var(--global-bg-color);
    text-decoration: none;
  }
  .book-sidebar-nav a.active {
    background: var(--global-theme-color);
    color: var(--global-bg-color);
    font-weight: 500;
  }
  .book-content {
    flex: 1;
    min-width: 0;
    padding: 1.5rem 0 1.5rem 2rem;
  }
  .book-content .post-title {
    margin-bottom: 0.5rem;
  }
  .book-nav-footer {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--global-divider-color);
  }
  .book-nav-footer a {
    font-size: 0.9rem;
  }
  @media (max-width: 768px) {
    .book-wrapper {
      flex-direction: column;
    }
    .book-sidebar {
      width: 100%;
      min-width: 100%;
      position: static;
      height: auto;
      overflow-y: visible;
      border-right: none;
      border-bottom: 1px solid var(--global-divider-color);
      padding: 1rem 0;
    }
    .book-content {
      padding: 1.5rem 0;
    }
  }
</style>

<div class="book-wrapper">
  {% include book-sidebar.liquid %}
  <div class="book-content">
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>
    <article>
      {{ content }}
    </article>
    {% assign collection_name = page.collection | default: page.book_collection %}
    {% assign chapters = site[collection_name] | sort: 'order' %}
    {% assign prev_chapter = nil %}
    {% assign next_chapter = nil %}
    {% assign found = false %}
    {% for chapter in chapters %}
      {% if found and next_chapter == nil %}
        {% assign next_chapter = chapter %}
      {% endif %}
      {% if chapter.url == page.url %}
        {% assign found = true %}
      {% endif %}
      {% unless found %}
        {% assign prev_chapter = chapter %}
      {% endunless %}
    {% endfor %}
    {% if prev_chapter or next_chapter %}
      <div class="book-nav-footer">
        <span>
          {% if prev_chapter %}
            <a href="{{ prev_chapter.url | relative_url }}">← {{ prev_chapter.title }}</a>
          {% endif %}
        </span>
        <span>
          {% if next_chapter %}
            <a href="{{ next_chapter.url | relative_url }}">{{ next_chapter.title }} →</a>
          {% endif %}
        </span>
      </div>
    {% endif %}
  </div>
</div>
