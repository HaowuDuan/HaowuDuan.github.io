---
import Base from '../layouts/Base.astro';
import { getCV } from '../lib/cv';

const cv = getCV();
---

<Base title="CV">
  <h1>CV</h1>

  {cv.summary && (
    <section class="card">
      <h2>Summary</h2>
      <p>{cv.summary}</p>
    </section>
  )}

  {cv.sections?.Education && (
    <section class="card">
      <h2>Education</h2>
      {cv.sections.Education.map((e: any) => (
        <div class="entry">
          <div class="entry-date">{e.start_date} – {e.end_date}</div>
          <div class="entry-body">
            <strong>{e.studyType} in {e.area}</strong>
            <div>{e.institution}</div>
            {e.location && <div class="location">{e.location}</div>}
          </div>
        </div>
      ))}
    </section>
  )}

  {cv.sections?.Experience && (
    <section class="card">
      <h2>Experience</h2>
      {cv.sections.Experience.map((e: any) => (
        <div class="entry">
          <div class="entry-date">{e.start_date} – {e.end_date}</div>
          <div class="entry-body">
            <strong>{e.position}</strong>
            <div>{e.company}</div>
            {e.location && <div class="location">{e.location}</div>}
            {e.summary && <div class="summary">{e.summary}</div>}
          </div>
        </div>
      ))}
    </section>
  )}

  {cv.sections?.Interests && (
    <section class="card">
      <h2>Research Interests</h2>
      {cv.sections.Interests.map((i: any) => (
        <p>{i.keywords}</p>
      ))}
    </section>
  )}

  {cv.sections?.['Talks and Conferences'] && (
    <section class="card">
      <h2>Talks and Conferences</h2>
      {cv.sections['Talks and Conferences'].map((t: any) => {
        const startYear = String(t.start_date).split('-')[0];
        const endYear = String(t.end_date).split('-')[0];
        const date = startYear === endYear ? startYear : `${startYear} – ${endYear}`;
        return (
          <div class="entry">
            <div class="entry-date">{date}</div>
            <div class="entry-body">
              <strong>{t.position}</strong>
              <div>{t.company}</div>
              {t.location && <div class="location">{t.location}</div>}
              {t.summary && <div class="summary">{t.summary}</div>}
            </div>
          </div>
        );
      })}
    </section>
  )}

  {cv.sections?.Skills && (
    <section class="card">
      <h2>Skills</h2>
      {cv.sections.Skills.map((s: any) => (
        <p><strong>{s.name}:</strong> {s.keywords}</p>
      ))}
    </section>
  )}
</Base>

<style>
  .card { margin-bottom: 1.5rem; }
  .card h2 { margin-top: 0; }
  .entry {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .entry:last-child { border-bottom: none; }
  .entry-date {
    min-width: 100px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 600;
  }
  .location { font-size: 0.85rem; color: var(--text-secondary); }
  .summary { font-size: 0.9rem; font-style: italic; color: var(--text-secondary); margin-top: 0.25rem; }
</style>
