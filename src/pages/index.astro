---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

let posts: any[] = [];
try {
  posts = (await getCollection('blog'))
    .sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 3);
} catch {}
---

<Base title="Haowu Duan">
  <div class="profile">
    <h1><span style="font-weight:700">Haowu</span> Duan</h1>
    <p class="subtitle">Theoretical Physicist · ML Researcher</p>
  </div>

  <div class="bio">
    <p>I am a theoretical high-energy physicist with a PhD from NC State and postdoctoral experience at UConn. My research background is in QCD at small Bjorken-x — the Color Glass Condensate, JIMWLK/BK evolution, and dipole phenomenology.</p>
    <p>I am interested in understanding deep learning systems through the lens of statistical mechanics and field theory, and in applying ML to problems in non-perturbative QCD. I am looking for research engineering and reinforcement learning positions at frontier AI labs.</p>
  </div>

  <div class="contact">
    <p>段昊武 (Haowu Duan) · hwdcgc [at] gmail.com</p>
    <div class="links">
      <a href="https://github.com/HaowuDuan" target="_blank" rel="noopener">GitHub</a>
      <a href="https://inspirehep.net/authors/2036679" target="_blank" rel="noopener">InspireHEP</a>
      <a href="https://scholar.google.com/citations?user=qc6CJjYAAAAJ" target="_blank" rel="noopener">Google Scholar</a>
    </div>
  </div>

  {posts.length > 0 && (
    <section>
      <h2><a href="/blog/">latest posts</a></h2>
      <ul class="post-list">
        {posts.map((post: any) => (
          <li>
            <span class="date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .profile { margin-bottom: 1.5rem; }
  .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
  .bio { margin-bottom: 2rem; max-width: 700px; }
  .contact { margin-bottom: 2rem; }
  .links { display: flex; gap: 1rem; margin-top: 0.5rem; }
  .post-list { list-style: none; padding: 0; }
  .post-list li { display: flex; gap: 1rem; padding: 0.4rem 0; }
  .date { color: var(--text-secondary); font-size: 0.9rem; min-width: 120px; }
</style>
