---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allTags = ['optimization', 'physics-of-ml', 'reinforcement-learning'];
let posts: any[] = [];
try {
  posts = (await getCollection('blog'))
    .sort((a: any, b: any) => {
      if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
      return b.data.date.getTime() - a.data.date.getTime();
    });
} catch {}
---

<Base title="Blog">
  <h1>Blog</h1>
  <div class="tags" id="tag-filters">
    <button class="tag-chip active" data-tag="all">all</button>
    {allTags.map(tag => (
      <button class="tag-chip" data-tag={tag}>{tag}</button>
    ))}
  </div>
  {posts.length === 0 ? (
    <p style="color: var(--text-secondary); margin-top: 2rem;">No posts yet.</p>
  ) : (
    <ul class="post-list" id="post-list">
      {posts.map((post: any) => (
        <li data-tags={post.data.tags.join(',')}>
          <span class="date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          <div>
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            {post.data.pinned && <span class="pin">📌</span>}
            <div class="post-tags">
              {post.data.tags.map((t: string) => <span class="tag-label">{t}</span>)}
            </div>
          </div>
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .post-list { list-style: none; padding: 0; }
  .post-list li { display: flex; gap: 1rem; padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
  .date { color: var(--text-secondary); font-size: 0.9rem; min-width: 120px; }
  .pin { margin-left: 0.5rem; }
  .post-tags { display: flex; gap: 0.4rem; margin-top: 0.2rem; }
  .tag-label { font-size: 0.75rem; color: var(--text-secondary); }
</style>

<script>
  document.querySelectorAll('#tag-filters .tag-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#tag-filters .tag-chip').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tag = (btn as HTMLElement).dataset.tag;
      document.querySelectorAll('#post-list li').forEach(li => {
        const tags = (li as HTMLElement).dataset.tags || '';
        (li as HTMLElement).style.display = (tag === 'all' || tags.includes(tag!)) ? '' : 'none';
      });
    });
  });
</script>
