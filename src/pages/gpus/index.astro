---
import Base from '../../layouts/Base.astro';
import { getNotes } from '../../lib/notes';

const chapters = await getNotes('gpu-notes');
---

<Base title="GPUs">
  <h1>GPUs</h1>
  <p style="margin-bottom: 2rem;">Notes on GPU architecture and programming.</p>
  {chapters.length === 0 ? (
    <p style="color: var(--text-secondary);">No chapters yet.</p>
  ) : (
    <ol class="chapter-list">
      {chapters.map(ch => (
        <li><a href={`/gpus/${ch.id}/`}>{ch.data.title}</a></li>
      ))}
    </ol>
  )}
</Base>

<style>
  .chapter-list { padding-left: 1.5rem; }
  .chapter-list li { padding: 0.4rem 0; }
</style>
