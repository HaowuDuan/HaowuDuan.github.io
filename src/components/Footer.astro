---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-container">
    &copy; {year} Haowu Duan. Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 1rem 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }
</style>
