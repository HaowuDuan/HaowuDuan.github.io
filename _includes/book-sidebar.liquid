<nav class="book-sidebar" aria-label="Book navigation">
  <h4 class="book-sidebar-title">
    <a href="{{ page.book_index | default: page.url | relative_url }}">{{ page.book_title | default: page.title }}</a>
  </h4>
  <ul class="book-sidebar-nav">
    {% assign collection_name = page.collection | default: page.book_collection %}
    {% assign chapters = site[collection_name] | sort: 'order' %}
    {% for chapter in chapters %}
      <li>
        <a href="{{ chapter.url | relative_url }}"
           {% if page.url == chapter.url %}class="active"{% endif %}>
          {{ chapter.title }}
        </a>
      </li>
    {% endfor %}
  </ul>
</nav>
